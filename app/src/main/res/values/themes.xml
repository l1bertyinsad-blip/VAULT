<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SAVIO" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/savio_white</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.SAVIO.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/savio_white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_savio_splash</item>
        <item name="windowSplashScreenAnimationDuration">700</item>
        <item name="postSplashScreenTheme">@style/Theme.SAVIO</item>
    </style>
</resources>
